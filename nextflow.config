params {
    // Input
    input            = null
    transcriptomes   = null
    reads            = null

    // Output
    outdir           = "results"
    tracedir         = "${params.outdir}/pipeline_info"

    // Coverage masking
    min_coverage     = 5             // Minimum read depth to retain a nucleotide position
    min_length       = 200           // Minimum contig length after masking

    // SNP calling
    min_base_quality = 20            // Minimum base quality for SNP calling
    min_map_quality  = 20            // Minimum mapping quality
    min_snp_depth    = 10            // Minimum depth to call a SNP
    max_missing      = 0.5           // Maximum fraction of missing data per site

    // Alignment & phylogenetics
    mafft_args          = '--retree 1 --reorder --thread 20'
    iqtree_model     = "TEST"        // IQ-TREE model selection (TEST = ModelFinder)
    iqtree_bootstrap = 1000          // Ultrafast bootstrap replicates
    iqtree_threads   = 4             // Threads per IQ-TREE run

    // Heterozygosity strategies
    run_collapsed    = true          // Run collapsed heterozygous sites strategy
    run_retained     = true          // Run retained heterozygous sites strategy

    // Report
    report_title     = "HeteroPhy Analysis Report"

    // Help
    help             = false
    enable_conda     = false

    // Resources
    max_cpus         = 20
    max_memory       = "128.GB"
    max_time         = "480.h"

}

/*
========================================================================================
    HeteroPhy Nextflow Configuration
========================================================================================
*/

// ─────────────────────────────────────────────────────────────────────────────
// GLOBAL DEFAULTS
// ─────────────────────────────────────────────────────────────────────────────

manifest {
    name            = 'HeteroPhy'
    author          = 'Your Lab'
    homePage        = 'https://github.com/[your-lab]/heterophy'
    description     = 'SNP & heterozygosity-aware phylogenetic inference from de novo transcriptomes'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// Default resource allocation per process
process {
    cpus   = { check_max(2    * task.attempt, 'cpus')   }
    memory = { check_max(8.GB * task.attempt, 'memory') }
    time   = { check_max(4.h  * task.attempt, 'time')   }

    errorStrategy = { task.exitStatus in [140, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // ── Per-process resource labels ───────────────────────────────────────────
    withLabel: process_low {
        cpus   = { check_max(2  * task.attempt, 'cpus')    }
        memory = { check_max(4.GB * task.attempt, 'memory') }
        time   = { check_max(2.h  * task.attempt, 'time')   }
    }
    withLabel: process_medium {
        cpus   = { check_max(6  * task.attempt, 'cpus')    }
        memory = { check_max(24.GB * task.attempt, 'memory') }
        time   = { check_max(8.h  * task.attempt, 'time')   }
    }
    withLabel: process_high {
        cpus   = { check_max(20 * task.attempt, 'cpus')    }
        memory = { check_max(64.GB * task.attempt, 'memory') }
        time   = { check_max(16.h * task.attempt, 'time')   }
    }
    withLabel: process_long {
        time   = { check_max(120.h * task.attempt, 'time')  }
    }
    withLabel: process_high_memory {
        memory = { check_max(96.GB * task.attempt, 'memory') }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// EXECUTION PROFILES
// ─────────────────────────────────────────────────────────────────────────────

profiles {

    // ── Conda ─────────────────────────────────────────────────────────────────
    conda {
        conda.enabled          = true
        conda.useMamba         = true       // faster solves; falls back to conda if absent
        conda.createTimeout    = '1 h'
        docker.enabled         = false
        singularity.enabled    = false
        params.enable_conda    = true
    }

    // ── Docker ────────────────────────────────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false
        process.container      = 'heterophy/heterophy:1.0.0'
    }

    // ── Singularity ───────────────────────────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        process.container      = 'docker://heterophy/heterophy:1.0.0'
    }

    // ── SLURM HPC ─────────────────────────────────────────────────────────────
    slurm {
        process.executor       = 'slurm'
        process.clusterOptions = '--account=your_account'   // ← edit for your HPC
        process.queue          = 'normal'
        executor {
            queueSize          = 200
            pollInterval       = '30 sec'
            submitRateLimit    = '10 sec'
        }
    }

    // ── PBS/Torque HPC ────────────────────────────────────────────────────────
    pbs {
        process.executor       = 'pbs'
        process.queue          = 'workq'
        executor {
            queueSize          = 100
            pollInterval       = '30 sec'
        }
    }

    // ── AWS Cloud ─────────────────────────────────────────────────────────────
    aws {
        process.executor       = 'awsbatch'
        process.container      = 'heterophy/heterophy:1.0.0'
        aws.region             = 'us-east-1'
        aws.batch.cliPath      = '/home/ec2-user/miniconda/bin/aws'
        workDir                = 's3://your-bucket/heterophy-work'  // ← edit
    }

    // ── Google Cloud ──────────────────────────────────────────────────────────
    gcp {
        process.executor       = 'google-lifesciences'
        process.container      = 'heterophy/heterophy:1.0.0'
        google.location        = 'us-central1'
        google.region          = 'us-central1'
        google.project         = 'your-project-id'              // ← edit
        workDir                = 'gs://your-bucket/heterophy-work' // ← edit
    }

    // ── Test profile (fast validation run) ────────────────────────────────────
    test {
        params.input           = "${projectDir}/tests/data/test_samplesheet.csv"
        params.outdir          = "test_results"
        params.min_coverage    = 3
        params.iqtree_bootstrap = 100
        params.iqtree_threads  = 2

        process {
            withLabel: process_high {
                cpus   = 4
                memory = '8.GB'
                time   = '1.h'
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORTING & TRACING
// ─────────────────────────────────────────────────────────────────────────────

timeline {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/execution_timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/execution_report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/execution_trace.txt"
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    overwrite = true
    file      = "results/pipeline_info/pipeline_dag.svg"
}

// ─────────────────────────────────────────────────────────────────────────────
// RESOURCE CAP FUNCTION
// ─────────────────────────────────────────────────────────────────────────────

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "ERROR: Max memory '${params.max_memory}' is not valid. Using default: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "ERROR: Max time '${params.max_time}' is not valid. Using default: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "ERROR: Max cpus '${params.max_cpus}' is not valid. Using default: $obj"
            return obj
        }
    }
}
